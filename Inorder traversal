Input: root = [1,2,3,4,5,null,8,null,null,6,7,9]

Output: [4,2,6,5,7,1,3,9,8]

class Solution {
    public List<Integer> inorderTraversal(TreeNode root) {
        ArrayList<Integer> hey=new ArrayList<>();
        inorder(root,hey);
        return hey;
    }

    private void inorder(TreeNode root,List<Integer>hey){
        if(root==null){
            return;
        }
            inorder(root.left,hey);
            hey.add(root.val);
            inorder(root.right,hey);
        
    }
}
